<li>
      <article class="mb-24">
          <a class="w-100" href="{{ curso.url }}">
            <div class="rat-1-1 w-100">
              <div class="rat-content">
                <img class="video-cover" width="100%" height="100%" src="{{ curso.data.image }}" alt="{{ curso.data.imageAlt }}"
                  class="h1">
              </div>
            </div>
                </a>
          <div class="article-text mt-24 p-16">
              <h3 class="fluid-9-b mb-16"><a href="{{ curso.url }}">{{ curso.data.title }}</a></h3>
      
     
              {# {% for tag in curso.data.tags %}
              <div class=" tag-info ">
                {{ tag }}
              </div>
              {% endfor %} #}

              <div class="descripcion-sistema">
                <h3 class="text-14-r"><a href="{{ curso.url }}">{{ curso.data.subtitle }}</a></h3>
                <p   class=" mbr-64 ">{{ curso.data.description }}</p>
              </div>

<div class="row">
  <div class="col-xs-6">          <p class="mb-8  text-12-r c-dark-grey">{{ curso.data.date | postDate }}</span></p></div>
  <div class="col-xs-6 text-right">    <a href="{{ curso.url }}" class="btn link-line"> Leer más</a>  </div>
</div> 

           
              
          </div>
      </article>
</li>